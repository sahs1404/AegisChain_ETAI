# Copy this file to ".env" (same folder) and fill in your key(s).
# .env is loaded automatically by explain_gemini.py / explain.py — no need
# to run "export" commands manually each terminal session.

# Free option — get one at https://aistudio.google.com/apikey (no card)
GEMINI_API_KEY=

# Optional fallback — only needed if you also want the Anthropic version
ANTHROPIC_API_KEY=
